# ─────────────────────────────────────────────────────────────────────
# AKAL — variables d'environnement requises
# Copier ce fichier en .env et remplir chaque valeur avant de lancer le projet.
# Ne jamais commiter le .env réel (il est dans .gitignore).
# ─────────────────────────────────────────────────────────────────────

# Clé secrète Django (obligatoire)
# Générer avec : python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=changeme-generate-a-real-key

# Base de données PostGIS (obligatoire)
# Format : postgis://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgis://akal:akal@localhost:5432/akal_db

# ─── Optionnel : chemins GDAL/GEOS ───────────────────────────────────
# Nécessaire uniquement si Django ne détecte pas automatiquement les
# bibliothèques (installation non-standard sur Windows ou macOS).
# Sur Linux/Docker avec gdal-bin installé via apt, laisser vide.
#
# Exemple Windows (PostgreSQL embarque GDAL) :
# GDAL_LIBRARY_PATH=C:\Program Files\PostgreSQL\18\bin\libgdal-35.dll
# GEOS_LIBRARY_PATH=C:\Program Files\PostgreSQL\18\bin\libgeos_c.dll
#
# Exemple macOS Homebrew (si non détecté automatiquement) :
# GDAL_LIBRARY_PATH=/opt/homebrew/lib/libgdal.dylib
# GEOS_LIBRARY_PATH=/opt/homebrew/lib/libgeos_c.dylib

# ─── Optionnel : origines CORS (production uniquement) ───────────────
# Liste séparée par des virgules des origines autorisées côté frontend.
# En dev, localhost:3000 est déjà autorisé dans settings/dev.py.
# CORS_ALLOWED_ORIGINS=https://akal.ma,https://www.akal.ma
